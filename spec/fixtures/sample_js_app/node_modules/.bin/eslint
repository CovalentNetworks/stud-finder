#!/bin/sh
if [ "$1" = "--version" ]; then
  echo "v9.0.0"
  exit 0
fi
printf '['
first=1
for arg in "$@"; do
  case "$arg" in
    *.js|*.jsx|*.ts|*.tsx)
      [ "$first" -eq 0 ] && printf ','
      first=0
      case "$arg" in
        src/hub.js) complexity=3 ;;
        *) complexity=1 ;;
      esac
      printf '{"filePath":"%s/%s","messages":[{"message":"Function has a complexity of %s. Maximum allowed is 0."}]}' "$PWD" "$arg" "$complexity"
      ;;
  esac
done
printf ']'
